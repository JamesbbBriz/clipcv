{
  "manifest_version": 3,
  "name": "clipcv",
  "version": "0.1.0",
  "description": "Convert the page you are viewing into a clean PDF or DOCX file via your own Vision LLM API key.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  }
}
