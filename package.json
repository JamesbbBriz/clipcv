{
  "name": "clipcv",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source Chrome extension that converts a single profile page into a clean PDF or DOCX file via a Vision LLM (BYOK).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "pdf-lib": "^1.17.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.4.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "0.1.40",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "6.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vitest": "^4.1.5"
  }
}
